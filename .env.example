# =========================
# XiaoBa-CLI Environment
# =========================

# LLM (Primary)
GAUZ_LLM_PROVIDER=anthropic
GAUZ_LLM_API_BASE=https://api.anthropic.com
GAUZ_LLM_API_KEY=your-api-key-here
GAUZ_LLM_MODEL=claude-sonnet-4-20250514

# LLM (Backup, optional)
GAUZ_LLM_BACKUP_PROVIDER=
GAUZ_LLM_BACKUP_API_BASE=
GAUZ_LLM_BACKUP_API_KEY=
GAUZ_LLM_BACKUP_MODEL=
# Failover behavior
GAUZ_LLM_FAILOVER_ON_ANY_ERROR=false
GAUZ_STREAM_FAILOVER_ON_PARTIAL=false
GAUZ_STREAM_RETRY=false
# Context token budget (optional, auto-detected by model)
# GAUZ_LLM_MAX_PROMPT_TOKENS=200000

# Feishu bot (optional, for `xiaoba feishu`)
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_ALIASES=小八,xiaoba

# CatsCompany bot (optional, for `xiaoba catscompany`)
CATSCOMPANY_SERVER_URL=wss://api.catsco.cc/v0/channels
CATSCOMPANY_API_KEY=your-catscompany-api-key
CATSCOMPANY_HTTP_BASE_URL=https://api.catsco.cc

# Weixin bot (optional, for `xiaoba weixin`)
WEIXIN_TOKEN=your-weixin-ilink-token
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
# WEIXIN_ALLOW_FROM=user1@im.wechat,user2@im.wechat

# Bot Bridge (optional, multi-bot collaboration)
# BRIDGE_SECRET=
# BOT_BRIDGE_NAME=
# BOT_BRIDGE_PORT=
# BOT_PEERS=
# BOT_EXPERTISE=

# Tool & filesystem safety overrides
GAUZ_TOOL_ALLOW=execute_shell,write_file,edit_file
GAUZ_FS_ALLOW_OUTSIDE_READ=true
GAUZ_FS_ALLOW_OUTSIDE=true

# Context debug logger (logs full context window to logs/context-debug/)
# CONTEXT_DEBUG=true
